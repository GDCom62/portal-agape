import json
import urllib.request

# URL pública e confiável contendo a Bíblia ACF completa em formato estruturado
url_fonte = "https://githubusercontent.com"

try:
    print("Baixando a Bíblia sagrada completa...")
    req = urllib.request.Request(url_fonte, headers={'User-Agent': 'Mozilla/5.0'})
    with urllib.request.urlopen(req, timeout=15) as response:
        dados_originais = json.loads(response.read().decode('utf-8'))
    
    biblia_completa = {}
    
    # Converte o formato do repositório para o formato exato que o seu app.py lê
    for livro in dados_originais:
        nome_livro = livro["name"]
        biblia_completa[nome_livro] = {}
        
        for idx_cap, capitulo in enumerate(livro["chapters"], start=1):
            biblia_completa[nome_livro][str(idx_cap)] = {}
            
            for idx_ver, texto_verso in enumerate(capitulo, start=1):
                biblia_completa[nome_livro][str(idx_cap)][str(idx_ver)] = texto_verso

    # Salva o arquivo final pronto para o seu GitHub
    with open("biblia.json", "w", encoding="utf-8") as f:
        json.dump(biblia_completa, f, ensure_ascii=False, indent=4)
        
    print("🎉 Arquivo 'biblia.json' completo gerado com sucesso!")

except Exception as e:
    print(f"Erro ao gerar o arquivo: {e}")
